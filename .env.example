# ── OpenAI / LLM ───────────────────────────────────────────
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o-mini

# ── Application ────────────────────────────────────────────
ENVIRONMENT=dev
LOG_LEVEL=INFO

# ── Database (MySQL) ───────────────────────────────────────
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/tarot

# ── Observability (Langfuse) ───────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
